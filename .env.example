# Copy to .env and fill in. Never commit .env.

# Blockfrost project key for the configured network (preview)
BLOCKFROST_API_KEY=preview_YOUR_KEY

# OPTIONAL: server-mode signing wallet for the REST API and the e2e scripts
# (generate with: npm run wallet:gen, then fund via faucet). The producer
# cockpit signs everything in a CIP-30 browser wallet and needs no server key.
# PRODUCER_PAYMENT_SKEY=<ed25519 private key hex>
# PRODUCER_ADDRESS=<addr_test1...>

# Off-chain payload encryption master key (32-byte hex); a dev default is
# derived when unset, set explicitly for anything beyond local development
ENCRYPTION_KEY=<64 hex chars>

# ZK prover 
DAYPASS_ZK_PROVER_URL=http://localhost:8799

# Optional
# DAYPASS_PUBLIC_URL=http://localhost:4004   # base for QR/resolver links
# DAYPASS_ANCHOR_GRANTS=true                 # public audit anchor per grant/revoke
# DAYPASS_ANCHOR_LABEL=1155                  # metadata label of the anchor payload
