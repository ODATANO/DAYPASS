<mvc:View
  controllerName="producer.controller.Detail"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m"
  xmlns:f="sap.ui.layout.form"
  xmlns:core="sap.ui.core">
  <Page title="Passport {passportId}" showNavButton="true" navButtonPress="onNavBack">
    <headerContent>
      <Button text="Attest" icon="sap-icon://wallet" press="onAttest"/>
      <Button text="Grant" enabled="{ui>/anchored}" icon="sap-icon://wallet" press="onGrantAction"/>
      <Button text="Revoke" enabled="{ui>/anchored}" icon="sap-icon://delete" press="onRevokeAction"/>
      <Button text="Disclose" enabled="{ui>/anchored}" icon="sap-icon://show" press="onDiscloseAction"/>
      <Button text="Share" enabled="{ui>/anchored}" icon="sap-icon://share-2" press="onShare"/>
      <Button text="Revoke passport" enabled="{ui>/anchored}" icon="sap-icon://cancel" press="onRevokePassport"/>
      <Button icon="sap-icon://refresh" tooltip="Refresh transactions" press="onRefresh"/>
    </headerContent>
    <content>
      <IconTabBar id="tabs" expandable="false" class="sapUiResponsiveContentPadding">
        <items>
          <!-- Overview -->
          <IconTabFilter text="Overview" icon="sap-icon://product">
            <f:SimpleForm editable="false" layout="ResponsiveGridLayout" labelSpanXL="4" labelSpanL="4">
              <f:content>
                <Label text="Passport ID"/><Text text="{passportId}"/>
                <Label text="Manufacturer"/><Text text="{manufacturerId}"/>
                <Label text="Model"/><Text text="{model}"/>
                <Label text="Category"/><Text text="{batteryCategory}"/>
                <Label text="Manufacture date"/><Text text="{manufactureDate}"/>
                <Label text="Weight (kg)"/><Text text="{weightKg}"/>
                <Label text="Performance class"/><Text text="{performanceClass}"/>
                <Label text="Status"/>
                <ObjectStatus text="{status}"
                  state="{= ${status} === 'anchored' ? 'Success' : ${status} === 'failed' ? 'Error' : ${status} === 'revoked' ? 'Error' : ${status} === 'anchoring' ? 'Warning' : 'None' }"/>
                <Label text="payloadHash"/><Text text="{payloadHash}"/>
                <Label text="Content root"/><Text text="{contentRoot}"/>
                <Label text="NFT unit"/><Text text="{= ${unit} || '—' }"/>
                <Label text="Fingerprint"/>
                <Link text="{= ${fingerprint} || '—' }"
                      href="{= ${fingerprint} ? 'https://preview.cardanoscan.io/token/' + ${fingerprint} : '' }"
                      target="_blank" enabled="{= !!${fingerprint} }"/>
                <Label text="Mint tx"/>
                <Link text="{= ${attestationTxHash} || 'not anchored' }"
                      href="{= ${attestationTxHash} ? 'https://preview.cardanoscan.io/transaction/' + ${attestationTxHash} : '' }"
                      target="_blank" enabled="{= !!${attestationTxHash} }"/>
                <Label text="Anchor version"/><Text text="{anchorVersion}"/>
                <Label text="Last anchor tx"/>
                <Link text="{= ${lastAnchorTxHash} || '—' }"
                      href="{= ${lastAnchorTxHash} ? 'https://preview.cardanoscan.io/transaction/' + ${lastAnchorTxHash} : '' }"
                      target="_blank" enabled="{= !!${lastAnchorTxHash} }"/>
              </f:content>
            </f:SimpleForm>
            <Table items="{batteries}" headerText="Cells">
              <columns>
                <Column><Text text="Serial"/></Column>
                <Column><Text text="Chemistry"/></Column>
                <Column><Text text="Capacity kWh"/></Column>
                <Column><Text text="Carbon kg CO2"/></Column>
                <Column><Text text="Supplier"/></Column>
              </columns>
              <items>
                <ColumnListItem>
                  <cells>
                    <Text text="{serialNumber}"/>
                    <Text text="{cellChemistry}"/>
                    <Text text="{capacityKwh}"/>
                    <Text text="{carbonFootprintKgCO2}"/>
                    <Text text="{supplierName}"/>
                  </cells>
                </ColumnListItem>
              </items>
            </Table>
          </IconTabFilter>

          <!-- Disclosure -->
          <IconTabFilter text="Disclosure" icon="sap-icon://locked" key="disc">
            <f:SimpleForm editable="true" layout="ResponsiveGridLayout" labelSpanXL="3" labelSpanL="3">
              <f:content>
                <Label text="Partner"/>
                <ComboBox id="granteePartner" items="{/Partners}" placeholder="select a registered partner">
                  <core:Item key="{granteeId}" text="{name} ({role})"/>
                </ComboBox>
                <Label text="Level"/>
                <Select id="grantLevel" selectedKey="1">
                  <core:Item key="0" text="0 · public / consumer"/>
                  <core:Item key="1" text="1 · legitimate-interest / recycler"/>
                  <core:Item key="2" text="2 · authority"/>
                </Select>
              </f:content>
            </f:SimpleForm>
            <Table id="discTable" items="{/DisclosureGrantLog}" growing="true" headerText="Disclosure log">
              <columns>
                <Column><Text text="Op"/></Column>
                <Column><Text text="Grantee"/></Column>
                <Column><Text text="Level"/></Column>
                <Column><Text text="Status"/></Column>
                <Column demandPopin="true" minScreenWidth="Desktop"><Text text="Tx"/></Column>
              </columns>
              <items>
                <ColumnListItem>
                  <cells>
                    <Text text="{op}"/>
                    <Text text="{grantee}"/>
                    <Text text="{level}"/>
                    <ObjectStatus text="{status}"
                      state="{= ${status} === 'confirmed' ? 'Success' : ${status} === 'failed' ? 'Error' : ${status} === 'submitted' || ${status} === 'pending' ? 'Warning' : 'None' }"/>
                    <Link text="{= ${txHash} || '—' }"
                          href="{= ${txHash} ? 'https://preview.cardanoscan.io/transaction/' + ${txHash} : '' }"
                          target="_blank" enabled="{= !!${txHash} }"/>
                  </cells>
                </ColumnListItem>
              </items>
            </Table>
          </IconTabFilter>

          <!-- Field disclosure (Track A) -->
          <IconTabFilter text="Field disclosure" icon="sap-icon://show" key="proof">
            <f:SimpleForm editable="true" layout="ResponsiveGridLayout" labelSpanXL="3" labelSpanL="3">
              <f:content>
                <Label text="Source field"/>
                <Select id="proofField" selectedKey="carbonFootprintKgCO2" change="onProofFieldChange">
                  <core:Item key="carbonFootprintKgCO2" text="Carbon footprint (kg CO₂ / kWh)"/>
                  <core:Item key="capacityKwh" text="Capacity (kWh)"/>
                  <core:Item key="recycledContentPct" text="Recycled content (%)"/>
                  <core:Item key="cycleLife" text="Cycle life (cycles)"/>
                  <core:Item key="roundTripEfficiencyPct" text="Round-trip efficiency (%)"/>
                  <core:Item key="leadContentPpm" text="Lead content (ppm)"/>
                  <core:Item key="recycledCoPct" text="Recycled cobalt (%)"/>
                  <core:Item key="recycledLiPct" text="Recycled lithium (%)"/>
                  <core:Item key="recycledNiPct" text="Recycled nickel (%)"/>
                </Select>
              </f:content>
            </f:SimpleForm>
            <Panel headerText="Disclosure result" expandable="true" expanded="true" visible="{= !!${disc>/json} }">
              <f:SimpleForm editable="false" layout="ResponsiveGridLayout" labelSpanXL="3" labelSpanL="3">
                <f:content>
                  <Label text="Value"/><Text text="{disc>/value}"/>
                  <Label text="Scaled (x1000)"/><Text text="{disc>/scaledValue}"/>
                  <Label text="Content root"/><Text text="{disc>/contentRoot}"/>
                </f:content>
              </f:SimpleForm>
              <Button text="Download disclosure JSON" icon="sap-icon://download" press="onDownloadDisclosure"/>
            </Panel>
            <Panel headerText="Zero-knowledge predicate" expandable="true" expanded="true" class="sapUiSmallMarginTop">
              <ObjectStatus class="sapUiSmallMarginBottom"
                text="{= ${poseidonRoot} ? 'Poseidon root anchored, proofs available' : 'No Poseidon root in the anchor yet: start the ZK prover, then attest again' }"
                state="{= ${poseidonRoot} ? 'Success' : 'Warning' }"
                icon="{= ${poseidonRoot} ? 'sap-icon://locked' : 'sap-icon://alert' }"/>
              <f:SimpleForm editable="true" layout="ResponsiveGridLayout" labelSpanXL="3" labelSpanL="3">
                <f:content>
                  <Label text="Predicate"/>
                  <Select id="zkPredicate" selectedKey="lessOrEqual">
                    <core:Item key="lessOrEqual" text="less or equal"/>
                    <core:Item key="greaterOrEqual" text="greater or equal"/>
                  </Select>
                  <Label text="Threshold"/>
                  <Input id="zkThreshold" type="Number" value="4000"/>
                  <Label text="Unit"/>
                  <Input id="zkUnit" value="kg CO₂ / kWh"/>
                </f:content>
              </f:SimpleForm>
              <Button text="Prove" icon="sap-icon://validate" enabled="{= ${ui>/anchored} &amp;&amp; !!${poseidonRoot} }" press="onProvePredicate"/>
            </Panel>
            <Table id="proofTable" items="{/PredicateProofLog}" growing="true" headerText="Disclosure / proof log">
              <columns>
                <Column><Text text="Field"/></Column>
                <Column><Text text="Mode"/></Column>
                <Column><Text text="Result"/></Column>
                <Column><Text text="Status"/></Column>
                <Column demandPopin="true" minScreenWidth="Desktop"><Text text="Tx"/></Column>
              </columns>
              <items>
                <ColumnListItem>
                  <cells>
                    <Text text="{sourceField}"/>
                    <Text text="{= ${mode} === 'zk' ? 'zk predicate' : 'merkle disclosure' }"/>
                    <ObjectStatus text="{= ${result} === null ? 'pending' : ${result} ? 'ok' : 'false' }"
                      state="{= ${result} === null ? 'None' : ${result} ? 'Success' : 'Error' }"/>
                    <ObjectStatus
                      text="{= ${mode} === 'merkle' &amp;&amp; ${status} === 'offline' ? 'verifiable via anchor' : ${status} }"
                      state="{= ${status} === 'confirmed' ? 'Success' : ${status} === 'failed' ? 'Error' : ${mode} === 'merkle' ? 'Success' : 'None' }"
                      tooltip="Merkle disclosures need no own transaction — the proof verifies against the contentRoot anchored by the attest tx."/>
                    <Link text="{= ${txHash} || '—' }"
                          href="{= ${txHash} ? 'https://preview.cardanoscan.io/transaction/' + ${txHash} : '' }"
                          target="_blank" enabled="{= !!${txHash} }"/>
                  </cells>
                </ColumnListItem>
              </items>
            </Table>
          </IconTabFilter>

          <!-- Transactions -->
          <IconTabFilter text="Transactions" icon="sap-icon://history" key="tx">
            <Table id="txTable" items="{/PassportTransactions}" growing="true">
              <columns>
                <Column><Text text="Step"/></Column>
                <Column><Text text="Status"/></Column>
                <Column demandPopin="true" minScreenWidth="Tablet"><Text text="Tx hash"/></Column>
                <Column demandPopin="true" minScreenWidth="Desktop"><Text text="When"/></Column>
              </columns>
              <items>
                <ColumnListItem>
                  <cells>
                    <Text text="{kind}"/>
                    <ObjectStatus text="{status}"
                      state="{= ${status} === 'confirmed' ? 'Success' : ${status} === 'failed' ? 'Error' : ${status} === 'pending' || ${status} === 'submitted' ? 'Warning' : 'None' }"/>
                    <Link text="{= ${txHash} || '—' }" href="{explorerUrl}" target="_blank" enabled="{= !!${explorerUrl} }"/>
                    <Text text="{createdAt}"/>
                  </cells>
                </ColumnListItem>
              </items>
            </Table>
          </IconTabFilter>

          <!-- Catena-X -->
          <IconTabFilter text="Catena-X" icon="sap-icon://supplier" key="cx">
            <VBox class="sapUiContentPadding">
              <Panel headerText="Battery Passport aspect" expandable="true" expanded="true">
                <HBox wrap="Wrap" class="sapUiTinyMarginBottom">
                  <Button text="Generate JSON" icon="sap-icon://create-form" press="onGenerateAspect" class="sapUiTinyMarginEnd"/>
                  <Button text="Download" icon="sap-icon://download" press="onDownloadAspect" enabled="{= !!${cx>/aspect} }"/>
                </HBox>
                <TextArea value="{cx>/aspect}" editable="false" width="100%" rows="14" growing="false"
                          placeholder="Generate the EU 2023/1542 / Catena-X aspect JSON from this passport."/>
              </Panel>
              <Panel headerText="Predicate Attestation Credential" expandable="true" expanded="true" class="sapUiSmallMarginTop">
                <HBox wrap="Wrap" class="sapUiTinyMarginBottom">
                  <Button text="Build PAC" icon="sap-icon://simulate" press="onBuildPac" class="sapUiTinyMarginEnd"/>
                  <Button text="Download" icon="sap-icon://download" press="onDownloadPac" enabled="{= !!${cx>/pac} }"/>
                </HBox>
                <Text text="A Catena-X CX-0143 verifiable credential built from this passport's disclosures and proofs, portably verifiable against Cardano (tractusx/pac/verify-pac.mjs)."
                      class="sapUiTinyMarginBottom"/>
                <TextArea value="{cx>/pac}" editable="false" width="100%" rows="14" growing="false"
                          placeholder="Build the PAC from the passport's exportable disclosures/proofs."/>
              </Panel>
            </VBox>
          </IconTabFilter>
        </items>
      </IconTabBar>
    </content>
  </Page>
</mvc:View>
