<mvc:View
  controllerName="producer.controller.Producer"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns="sap.m">
  <Page title="Battery Passports" showNavButton="false">
    <headerContent>
      <ObjectStatus text="{= 'wallet: ' + ${session>/ownerShort} }" state="Success" visible="{= !!${session>/walletConnected} }"/>
      <Button icon="sap-icon://log" tooltip="Disconnect wallet" press="onDisconnectWallet" visible="{= !!${session>/walletConnected} }"/>
      <Button id="connectWalletBtn" text="Connect wallet" icon="sap-icon://wallet" press="onConnectWallet" visible="{= !${session>/walletConnected} }"/>
      <Button text="Create passport" type="Emphasized" icon="sap-icon://add" press="onCreate"/>
      <Button text="Register partner" icon="sap-icon://add-employee" press="onRegisterPartner"/>
      <Button icon="sap-icon://refresh" tooltip="Refresh" press="onRefresh"/>
    </headerContent>
    <content>
      <MessageStrip text="Connect your Cardano wallet to see and manage your passports."
                    type="Information" showIcon="true" class="sapUiSmallMargin"
                    visible="{= !${session>/walletConnected} }"/>
      <Table id="passportTable" growing="true" growingThreshold="50"
             items="{path: '/Passports', parameters: {'$count': true}, filters: {path: 'owner', operator: 'EQ', value1: '__not_connected__'}}"
             mode="None" itemPress="onOpen" visible="{= !!${session>/walletConnected} }">
        <headerToolbar>
          <OverflowToolbar>
            <Title text="{= 'Passports (' + (${session>/passportCount} || 0) + ')' }"/>
            <ToolbarSpacer/>
          </OverflowToolbar>
        </headerToolbar>
        <columns>
          <Column><Text text="Passport ID"/></Column>
          <Column><Text text="Model"/></Column>
          <Column demandPopin="true" minScreenWidth="Tablet"><Text text="Category"/></Column>
          <Column><Text text="Status"/></Column>
          <Column demandPopin="true" minScreenWidth="Desktop"><Text text="Attestation tx"/></Column>
        </columns>
        <items>
          <ColumnListItem type="Navigation">
            <cells>
              <ObjectIdentifier title="{passportId}" text="{manufacturerId}"/>
              <Text text="{model}"/>
              <Text text="{batteryCategory}"/>
              <ObjectStatus text="{status}"
                state="{= ${status} === 'anchored' ? 'Success' : ${status} === 'failed' ? 'Error' : ${status} === 'anchoring' ? 'Warning' : 'None' }"/>
              <Link text="{= ${attestationTxHash} ? ${attestationTxHash} : 'not anchored' }"
                    href="{= ${attestationTxHash} ? 'https://preview.cardanoscan.io/transaction/' + ${attestationTxHash} : '' }"
                    target="_blank" enabled="{= !!${attestationTxHash} }"/>
            </cells>
          </ColumnListItem>
        </items>
      </Table>

      <Panel headerText="Registered dataspace partners" expandable="true" expanded="true" class="sapUiMediumMarginTop">
        <Table id="partnersTable" items="{/Partners}">
          <columns>
            <Column><Text text="Name"/></Column>
            <Column><Text text="Role"/></Column>
            <Column demandPopin="true" minScreenWidth="Tablet"><Text text="DID / BPN"/></Column>
            <Column demandPopin="true" minScreenWidth="Desktop"><Text text="granteeId"/></Column>
          </columns>
          <items>
            <ColumnListItem>
              <cells>
                <ObjectIdentifier title="{name}"/>
                <ObjectStatus text="{role}" state="{= ${role} === 'authority' ? 'Warning' : 'Information' }"/>
                <Text text="{did}"/>
                <Text text="{granteeId}"/>
              </cells>
            </ColumnListItem>
          </items>
        </Table>
      </Panel>
    </content>
  </Page>
</mvc:View>
